{
  "name": "Node Health",
  "target": "section",
  "stylesheet": "tf-storefront.css",
  "javascript": "tf-storefront.js",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Widget Label",
      "default": "Manufacturing Health"
    },
    {
      "type": "text",
      "id": "api_proxy_url",
      "label": "API Proxy URL",
      "default": "/apps/thunderfire/api/proxy",
      "info": "Uses Shopify App Proxy - no CORS issues"
    },
    {
      "type": "range",
      "id": "refresh_seconds",
      "label": "Refresh Interval (seconds)",
      "min": 10,
      "max": 300,
      "step": 10,
      "default": 30
    }
  ]
}
