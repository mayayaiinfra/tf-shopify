{
  "name": "tf-shopify",
  "version": "1.0.0",
  "private": true,
  "description": "THUNDERFIRE autonomous node management for Shopify merchants",
  "license": "MIT",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "deploy": "shopify app deploy",
    "docker-start": "npm run setup && remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest",
    "shopify": "shopify"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "@remix-run/node": "^2.11.0",
    "@remix-run/react": "^2.11.0",
    "@remix-run/serve": "^2.11.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.3.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.0",
    "isbot": "^5.1.0",
    "prisma": "^5.19.0",
    "react": "^19.2.4",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
