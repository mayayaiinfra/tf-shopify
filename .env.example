# Shopify (filled by Shopify CLI on first `shopify app dev`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://tf-shopify.fly.dev
SCOPES=read_products,write_products,read_orders,read_inventory,write_inventory

# Database (default: SQLite for dev, change to PostgreSQL for production)
DATABASE_URL=file:dev.db

# THUNDERFIRE (set per-shop in admin, but can override globally here)
# THUNDERFIRE_API_URL=https://top.mayayai.com
# THUNDERFIRE_API_KEY=tf_live_...
